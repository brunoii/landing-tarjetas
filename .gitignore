# Build output
target/
build/
out/
*.class
*.jar
*.war
*.ear

# Local runtime data: keep placeholders, ignore real contents
data/*
!data/.gitkeep
exports/*
!exports/.gitkeep
logs/*
!logs/.gitkeep
uploads/*
!uploads/.gitkeep
tmp/*
!tmp/.gitkeep

# Sensitive financial inputs and generated artifacts
*.pdf
*.PDF
*.csv
*.xlsx
*.xls
*.ofx
*.qif
*.db
*.db-shm
*.db-wal
*.h2.db
*.h2.db.mv.db
*.mv.db
*.trace.db
*.lock.db
*.lock
*.sqlite
*.sqlite3

# Logs and temporary files
*.log
*.tmp
*.temp
*.bak
*.swp
.DS_Store
Thumbs.db

# Local configuration and secrets
.env
.env.*
!.env.example
*.env
*.env.*
!.env.example
application-local.properties
application-local.yml
application-private.properties
application-private.yml
application-prod-local.properties
application-prod-local.yml

# Local AI/tooling metadata with machine-specific paths
.atl/

# IDE and editor files
.idea/
*.iml
.vscode/
.settings/
.project
.classpath

# Maven wrapper cache if added later
.mvn/wrapper/maven-wrapper.jar
